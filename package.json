{
  "name": "habit-tracker",
  "version": "1.0.0",
  "description": "Self-hosted habit streak tracker",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "node --watch src/server.js",
    "start": "node src/server.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^2.0.0"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true,
    "esbuild@0.21.5": true
  }
}
